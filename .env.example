###############################################################################
# Mercado Livre OAuth configuration
#
# OAuth is managed by a human.
# Business code MUST NOT implement OAuth.
# If the access token expires, a human must generate a new one.
###############################################################################

# OAuth Application

ML_CLIENT_ID=xxxxxxxxxxxxxxxx
ML_CLIENT_SECRET=xxxxxxxxxxxxxxxx

# Human-maintained credentials

ML_ACCESS_TOKEN=xxxxxxxxxxxxxxxx

# API

ML_SITE_ID=MLB
ML_API_BASE_URL=https://api.mercadolibre.com
